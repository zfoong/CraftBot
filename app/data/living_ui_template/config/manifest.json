{
  "id": "{{PROJECT_ID}}",
  "name": "{{PROJECT_NAME}}",
  "version": "1.0.0",
  "description": "{{PROJECT_DESCRIPTION}}",
  "author": "CraftBot Agent",
  "livingUIVersion": "1.0",
  "features": [],
  "createdAt": "{{CREATED_AT}}",
  "entrypoint": {
    "frontend": "src/main.tsx",
    "backend": "backend/main.py"
  },
  "ports": {
    "frontend": {{PORT}},
    "backend": {{BACKEND_PORT}}
  },
  "pipeline": {
    "backend": {
      "cwd": "backend",
      "install": "python -m pip install -r requirements.txt",
      "tests": [
        {"name": "internal", "command": "python test_runner.py --internal", "required": true},
        {"name": "unit", "command": "python test_runner.py --unit", "required": true},
        {"name": "agent_tests", "command": "python -m pytest tests/ -v --tb=short", "required": true},
        {"name": "compatibility", "command": "python test_runner.py --compatibility", "required": false}
      ],
      "start": "python -m uvicorn main:app --host 0.0.0.0 --port {{BACKEND_PORT}}",
      "health": "http://localhost:{{BACKEND_PORT}}/health",
      "post_start_tests": [
        {"name": "external", "command": "python test_runner.py --external --port {{BACKEND_PORT}}", "required": true}
      ]
    },
    "frontend": {
      "cwd": ".",
      "install": "npm install",
      "build": "npm run build",
      "start": "npm run preview -- --port {{PORT}}",
      "health": null
    }
  },
  "agentAwareness": {
    "enabled": true,
    "stateReportInterval": 1000,
    "reportComponents": true,
    "reportUserInputs": true,
    "reportVisibleText": true
  },
  "theme": "{{THEME}}"
}
